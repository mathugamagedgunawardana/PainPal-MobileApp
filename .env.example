# Gemini AI API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Deployed Next.js API origin (no trailing slash). Used when the user has not set "API Base URL" in app Settings.
# Local dev (Android emulator): use 127.0.0.1 + adb reverse (see scripts/android-reverse-port.sh).
# Local dev (alternative): API_ANDROID_USE_LOCALHOST=false — app uses 10.0.2.2 instead of 127.0.0.1.
# Production / emulator without local server: https://painpal-web.vercel.app
# MRI uploads require the Next.js server to have BLOB_READ_WRITE_TOKEN (Vercel Blob) configured.
API_BASE_URL=http://127.0.0.1:3000
API_ANDROID_USE_LOCALHOST=true

