# Gemini AI API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Deployed Next.js API origin (no trailing slash). Used when the user has not set "API Base URL" in app Settings.
# Local dev: http://127.0.0.1:3000 — Android emulator resolves localhost/127.0.0.1 to 10.0.2.2 automatically in code.
# Production: https://your-domain.example.com
API_BASE_URL=http://127.0.0.1:3000

